# Server
PORT=4000
NODE_ENV=development

# kaga (graph service — persistence backend, PostgreSQL-backed)
KAGA_URL=http://localhost:8090
KAGA_API_KEY=dev-kosmos-key

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Storage (local | s3)
STORAGE_DRIVER=local
STORAGE_BASE_PATH=./data/assets

# Auth
AUTH_ENABLED=false
JWT_SECRET=dev-secret
